# Lethe Configuration Example
# Copy to .env and fill in your values

# Telegram (required)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ALLOWED_USER_IDS=123456789

# LLM Provider - one of: openrouter, anthropic, openai
# If not set, auto-detects from available API keys/OAuth tokens
# LLM_PROVIDER=openrouter

# API keys - set the one for your provider (or use OAuth tokens below)
OPENROUTER_API_KEY=your_key_here
# ANTHROPIC_API_KEY=your_key_here
# OPENAI_API_KEY=your_key_here

# OAuth tokens (optional alternatives to API keys)
# ANTHROPIC_AUTH_TOKEN=sk-ant-oat01-...
# OPENAI_AUTH_TOKEN=eyJ...

# Model (optional, uses provider default if not set)
# LLM_MODEL=moonshotai/kimi-k2.5

# Heartbeat (optional)
# HEARTBEAT_INTERVAL=3600
# HEARTBEAT_ENABLED=true

# Hippocampus memory recall (optional)
# HIPPOCAMPUS_ENABLED=true

# Debug logging (default: false)
# LLM_DEBUG=false
# LLM_DEBUG_DIR=logs/llm

# OAuth token file overrides (optional)
# LETHE_ANTHROPIC_OAUTH_TOKENS=~/.lethe/oauth_tokens.json
# LETHE_OPENAI_OAUTH_TOKENS=~/.lethe/openai_oauth_tokens.json
# Legacy Anthropic override still supported: LETHE_OAUTH_TOKENS

# Subconscious layer — local model (optional)
# LLM_LOCAL_ENABLED=true
# LLM_LOCAL_MODEL=ollama/qwen3:8b
# LLM_LOCAL_API_BASE=http://localhost:11434

# Dream processing — LoRA finetuning loop (optional)
# DREAM_TRAIN_THRESHOLD=50           # Min new examples before triggering training
# DREAM_BASE_MODEL=Qwen/Qwen3-8B-Instruct   # HuggingFace base model for LoRA
# DREAM_OLLAMA_MODEL=lethe-dreamer   # Ollama model name for trained model
