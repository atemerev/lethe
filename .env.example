# Lethe configuration example.
# Copy to .env or ~/.lethe/config/.env and fill in your values.

# Runtime paths.
# LETHE_HOME=~/.lethe
# WORKSPACE_DIR=~/.lethe/workspace
# MEMORY_DIR=~/.lethe/data/memory
# DB_PATH=~/.lethe/data/lethe.db
# LOGS_DIR=~/.lethe/logs

# Logging. Default is info.
# RUST_LOG=debug
# Full LLM request/response JSON dumps. Contains prompts, memory, tool schemas,
# tool results, and attachments; keep private.
# LLM_DEBUG=false
# LLM_DEBUG_DIR=~/.lethe/logs/llm

# Runtime mode: cli, telegram, or api.
# LETHE_MODE=telegram

# Telegram.
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ALLOWED_USER_IDS=123456789

# LLM provider: openrouter, anthropic, openai, or local OpenAI-compatible.
# Optional; useful when the model id does not include a provider prefix.
# LLM_PROVIDER=openrouter

# API keys - set the one for your provider.
OPENROUTER_API_KEY=your_key_here
# ANTHROPIC_API_KEY=your_key_here
# OPENAI_API_KEY=your_key_here

# Anthropic subscription/OAuth mode.
# ANTHROPIC_AUTH_TOKEN=your_access_token_here
# LETHE_ANTHROPIC_OAUTH_TOKENS=~/.lethe/credentials/anthropic_oauth_tokens.json

# Local OpenAI-compatible server, e.g. llama.cpp.
# LLM_PROVIDER=openai
# LLM_API_BASE=http://localhost:8090/v1
# OPENAI_API_KEY=local

# Model
# LLM_MODEL=openrouter/moonshotai/kimi-k2.6
# LLM_MODEL_AUX=openrouter/google/gemini-3-flash-preview
# LLM_CONTEXT_LIMIT=100000

# Heartbeat (optional)
# HEARTBEAT_INTERVAL=3600
# HEARTBEAT_ENABLED=true

# Hippocampus memory recall (optional)
# HIPPOCAMPUS_ENABLED=true

# Semantic memory search (optional)
# LETHE_SEMANTIC_SEARCH_ENABLED=true
# LETHE_EMBEDDING_PROVIDER=fastembed
# LETHE_EMBEDDING_MODEL=Snowflake/snowflake-arctic-embed-m-v2.0
